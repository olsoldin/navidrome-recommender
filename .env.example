# Copy this file to .env and fill in your Navidrome server details.

# The base URL of your Navidrome server (no trailing slash)
NAVIDROME_URL=https://navidrome.example.com

# A Navidrome username and password (a dedicated read-only-feeling account
# is fine — this app only reads your library, play history, and starred
# items; it never writes anything back to Navidrome).
NAVIDROME_USER=your-username
NAVIDROME_PASS=your-password
